{
  "name": "zhead",
  "type": "module",
  "version": "2.2.4",
  "description": "All the types you need for your <head>",
  "author": "Harlan Wilton <harlan@harlanzw.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/harlan-zw",
  "homepage": "https://github.com/harlan-zw/zhead#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harlan-zw/zhead.git",
    "path": "packages/zhead"
  },
  "bugs": {
    "url": "https://github.com/harlan-zw/zhead/issues"
  },
  "keywords": [
    "head",
    "types"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "dev:prepare": "obuild --stub",
    "typecheck": "tsc --noEmit",
    "test:attw": "attw --pack",
    "prepack": "pnpm run build"
  }
}

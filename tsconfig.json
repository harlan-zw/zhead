{
  "compilerOptions": {
    "target": "esnext",
    "moduleDetection": "force",
    "rootDir": ".",
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["node", "vitest/globals"],
    "allowImportingTsExtensions": true,
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": ["scripts"]
}
